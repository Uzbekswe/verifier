# Copy to .env and adjust for your environment

APP_NAME="Photo Verification API"
VERSION="1.0.0"
DEBUG=false

# Image limits
MAX_IMAGE_SIZE_MB=10
MAX_IMAGE_DIMENSION=4096

# CV concurrency
CV_THREAD_POOL_SIZE=4

# Rate limiting (use redis://... in production)
RATE_LIMIT_STORAGE_URI=memory://
RATE_LIMIT_GLOBAL=200/minute
RATE_LIMIT_SUBMIT=10/minute
RATE_LIMIT_CHALLENGE=30/minute

# Liveness threshold
LIVENESS_THRESHOLD=0.6

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS (restrict in production)
CORS_ORIGINS=["*"]
